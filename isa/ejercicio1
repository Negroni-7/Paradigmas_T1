#include <iostream>// entrada y salida de datos
#include <cmath> // para utilizar el comando pow
using namespace std;

float sum1 ( int n ) //función para la sumatoria 1 
{
    float x = 1.0 , s1 = 0; // x debe ser float para hacer correctamente la operación de s1.
    while (x  <= n) // la condición siempre debe ir en parentesis
    {
        s1 =  s1 + ( 1.0 / x);
        x +=1.0; //decimales deben ir con punto no con coma
    }
    return s1;//debe ir fuera del while porque sino se ejecuta una vez y saldrá de la función.
}

float sum2 ( int n )
{
    float x = 1.0, s2 = 0 ;
    while ( x <= n )
    {
        s2 += x / pow (x+1,2);// se utiliza pow para calcular potencias (base,exponente)
        x += 1.0; 
    }
    return s2;
}

float sum3 ( int n, int k)
{
    int base = k, x = 1;
    float s3 = 0.0;
    while ( x <= n)
    {
        s3 += x / pow(k,x);
        x+=1;
    }
    return s3;
}

